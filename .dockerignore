# The cv-app image copies only index.html + nginx.conf explicitly, so the
# entries below are belt-and-suspenders: they keep source/docs out of the
# build context entirely. Nothing here may ever be web-reachable.
.git
.gitignore
.dockerignore
Dockerfile
docker-compose.yml
README.md
claude-design-prompt.md
docs/
api/
**/__pycache__/
**/*.pyc
